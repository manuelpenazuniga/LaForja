# =====================================================================
# LA FORJA — environment variables (example). NEVER put real secrets here.
# Copy to `.env.local` (git-ignored) and fill in OPENAI_API_KEY.
# =====================================================================

# --- GPT-5.6 compliance (NON-NEGOTIABLE hackathon requirement) -----------
# Both IDs MUST start with "gpt-5.6". The guard in src/config/models.ts sets
# compliance:false and warns loudly if they do not. The eval runner REFUSES
# to write results when the model family is not gpt-5.6 (invalid evidence).
REVIEWER_MODEL=gpt-5.6-terra
ADJUDICATOR_MODEL=gpt-5.6-sol

# --- OpenAI --------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_ME

# --- Database (SQLite via Prisma) ----------------------------------------
DATABASE_URL="file:./dev.db"

# --- Public demo isolation (doc §10) -------------------------------------
SESSION_TTL_MINUTES=30          # auto-reset per visitor
MAX_INPUT_CHARS=4000            # input size limit (UNTRUSTED text)
RATE_LIMIT_PER_MINUTE=20        # per-SESSION requests (defence in depth only:
                                #   bypassed by never sending a cookie)
IP_RATE_LIMIT_PER_MINUTE=120    # per-CLIENT-ADDRESS requests, cookie or not
SESSION_CREATE_PER_MINUTE=10    # per-CLIENT-ADDRESS session minting
GLOBAL_SESSION_CREATE_PER_MINUTE=60
                                # session minting across ALL addresses. The only
                                #   budget a spoofed X-Forwarded-For cannot reset.
                                #   See the trust model in src/demo/isolation.ts.

# --- Reviewer orchestration (doc §7.1) -----------------------------------
REVIEWER_TIMEOUT_MS=30000       # per-reviewer timeout (Promise.allSettled)
PROMPT_VERSION=v1               # logged on every ModelCall (constraint 3)

# --- Eval variant (doc §7.4) — NEVER the default -------------------------
# Comparison-only in the eval; the primary path is 3 concurrent Responses calls.
MULTI_AGENT_VARIANT=false
